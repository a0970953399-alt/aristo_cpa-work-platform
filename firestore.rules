rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, delete: if true;
      allow create: if !request.resource.data.keys().hasAny([
        'googleUid',
        'googleEmail',
        'googleDisplayName'
      ]);
      allow update: if !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'googleUid',
        'googleEmail',
        'googleDisplayName'
      ]);
    }

    // These collections contain OAuth credentials or approval state and are
    // accessible only through Firebase Admin in Cloud Functions.
    match /{collection}/{document=**} {
      allow read, write: if collection != 'users'
        && collection != 'calendarConnections'
        && collection != 'googleBindingRequests'
        && collection != 'googleOAuthStates';
    }
  }
}
